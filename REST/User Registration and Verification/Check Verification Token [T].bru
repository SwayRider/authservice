meta {
  name: Check Verification Token [T]
  type: http
  seq: 3
}

post {
  url: {{AUTHSERVICE_HOST}}:{{AUTHSERVICE_PORT}}/api/v1/auth/internal/check-verification-token
  body: json
  auth: inherit
}

body:json {
  {
    "userId": "{{verification_user_id}}",
    "token": "{{verification_token}}"
  }
}
