meta {
  name: Create Verification Token [L]
  type: http
  seq: 2
}

get {
  url: {{AUTHSERVICE_HOST}}:{{AUTHSERVICE_PORT}}/api/v1/auth/internal/create-verification-token
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

script:post-response {
  if (res.status == 200) {
    if (res.body.token !== undefined) {
      bru.setVar("verification_token", res.body.token);
    }
    if (res.body.userId !== undefined) {
      bru.setVar("verification_user_id", res.body.userId);
    }
  }
}
