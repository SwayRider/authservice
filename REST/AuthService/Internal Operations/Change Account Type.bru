meta {
  name: Change Account Type
  type: http
  seq: 5
}

post {
  url: {{AUTHSERVICE_HOST}}:{{AUTHSERVICE_PORT}}/api/v1/auth/internal/change-account-type
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "userId": "{{subject_user_id}}",
    "accountType": "premium"
  }
}
