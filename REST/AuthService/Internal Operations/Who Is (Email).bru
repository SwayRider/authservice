meta {
  name: Who Is (Email)
  type: http
  seq: 3
}

post {
  url: {{AUTHSERVICE_HOST}}:{{AUTHSERVICE_PORT}}/api/v1/auth/internal/whois
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "email": "maa.rten.heremans@gmail.com"
  }
}

script:post-response {
  if (res.status == 200) {
    if (res.body.userId !== undefined) {
      bru.setEnvVar("subject_user_id", res.body.userId);
    }
  }
}
