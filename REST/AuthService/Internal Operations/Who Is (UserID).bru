meta {
  name: Who Is (UserID)
  type: http
  seq: 4
}

post {
  url: {{AUTHSERVICE_HOST}}:{{AUTHSERVICE_PORT}}/api/v1/auth/internal/whois
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{access_token}}
}

body:json {
  {
    "userId": "{{subject_user_id}}"
  }
}

script:post-response {
  if (res.status == 200) {
    if (res.body.email !== undefined) {
      bru.setEnvVar("subject_email", res.body.email);
    }
  }
}
